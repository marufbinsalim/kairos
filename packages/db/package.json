{
  "name": "@kairos/db",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "migrate:run": "ts-node -r tsconfig-paths/register ./src/migrate.ts",
    "migrate:generate": "typeorm migration:generate -d ./src/data-source.ts"
  },
  "dependencies": {
    "typeorm": "^0.3.20",
    "pg": "^8.11.5",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  }
}
